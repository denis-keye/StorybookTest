# GitHub Personal Access Token — required for the Design Panel "Create PR" feature.
# Needs: repo scope (read + write + PR creation)
#
# Create one at: https://github.com/settings/tokens/new
# Select scopes: repo → "Full control of private repositories"  (or just "repo:status" + "public_repo" for public repos)
#
# Copy this file to .env.local and fill in your token:
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
